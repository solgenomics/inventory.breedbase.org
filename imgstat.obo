[Term]
id: IMGSTAT:0000003
name: has_color_card
def: "Boolean indicator specifying whether a valid color calibration card was detected in the image by the analysis pipeline." []
relationship: variable_of IMGSTAT:0000002 ! Reference Object Trait

!Boolean indicator specifying whether a valid color calibration card was detected in the image by the analysis pipeline.	has_color_card	Reference Object Trait	Categorical	True/False

[Term]
id: IMGSTAT:0000004
name: has_size_marker
def: "Boolean indicator specifying whether a valid physical size marker was detected in the image by the analysis pipeline." []
relationship: variable_of IMGSTAT:0000002 ! Reference Object Trait

!Boolean indicator specifying whether a valid physical size marker was detected in the image by the analysis pipeline.	has_size_marker	Reference Object Trait	Categorical	True/False

